// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  // need to add -js
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model User {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  email     String   @unique
  name      String?
  age       Int
  posts     Post[] // alt + shift + F
  orders    Order[]
  // 1 user has many orders
}

model Post {
  id        Int     @id @default(autoincrement())
  title     String
  content   String?
  published Boolean @default(false)
  user      User?   @relation(fields: [userId], references: [id]) // relationship
  userId    Int? //FK
}

model Product {
  id         Int         @id @default(autoincrement())
  name       String
  price      Float       @default(0)
  stock      Int         @default(0)
  orderItems OrderItem[]
  // 1 product can exist in many order items
}

model Order {
  id         Int         @id @default(autoincrement())
  orderDate  DateTime    @default(now())
  user       User?       @relation(fields: [userId], references: [id])
  userId     Int? //FK
  orderItems OrderItem[]
  // 1 order has many order items
}

model OrderItem {
  id          Int      @id @default(autoincrement())
  quantity    Int
  priceAtTime Float
  order       Order?   @relation(fields: [orderId], references: [id])
  orderId     Int? //FK
  product     Product? @relation(fields: [productId], references: [id])
  productId   Int? //FK
}

model Author {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(100)
  books Book[]
  // 1 author has many books
}

model Book {
  id         Int        @id @default(autoincrement())
  title      String     @db.VarChar(200)
  author     Author?    @relation(fields: [authorId], references: [id])
  authorId   Int?
  bookStatus BookStatus
}

enum BookStatus {
  published
  pending
  discontinued
}

model Classroom {
  id         Int       @id @default(autoincrement())
  name       String?
  gradeLevel String
  students   Student[]
  // 1 classroom has many students
}

model Student {
  id                Int               @id @default(autoincrement())
  name              String
  classroom         Classroom?        @relation(fields: [classroomId], references: [id])
  classroomId       Int?
  // 1 student has many student activity
  studentActivities StudentActivity[]
}

enum ActivityType {
  SPORT
  CULTURE
  ACADEMIA
}

model Activity {
  id                Int               @id @default(autoincrement())
  title             String
  type              ActivityType
  // 1 activity has many student activities
  studentActivities StudentActivity[]
}

model StudentActivity {
  joinDate   DateTime  @default(now())
  student    Student?  @relation(fields: [studentId], references: [id])
  studentId  Int
  activity   Activity? @relation(fields: [activityId], references: [id])
  activityId Int
  @@id([studentId, activityId])
}
